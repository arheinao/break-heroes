# Cloudflare Pages redirects
# Docs: https://developers.cloudflare.com/pages/configuration/redirects/

# Default locale: redirect bare paths to /en/ equivalents.
/                       /en/                            302
/destinations           /en/destinations/               301
/destinations/*         /en/destinations/:splat         301
/search                 /en/search/                     301
/about                  /en/about/                      301

# Legacy redirects
/find-dates             /en/search/                     301
/find-my-dates          /en/search/                     301

# trailingSlash=true is set in next.config.ts so unslashed URLs redirect automatically.
